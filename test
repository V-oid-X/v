-- Toggle Creator
local function createToggle(name)
	local btn = Instance.new("TextButton", frame)
	btn.Size = UDim2.new(0.9,0,0,40)
	btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
	btn.TextColor3 = Color3.fromRGB(255,255,255)
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 16
	btn.Text = name .. ": OFF"
	
	local c = Instance.new("UICorner", btn)
	c.CornerRadius = UDim.new(0,10)
	
	local enabled = false
	
	btn.MouseButton1Click:Connect(function()
		enabled = not enabled
		btn.Text = name .. ": " .. (enabled and "ON" or "OFF")
		
		-- Hook your own game logic here
		print(name, enabled)
	end)
end

-- Toggles (safe placeholders)
createToggle("Fly")
createToggle("NoClip")
createToggle("ESP")
createToggle("God")

-- Speed Slider Label
local speedLabel = Instance.new("TextLabel", frame)
speedLabel.Size = UDim2.new(0.9,0,0,30)
speedLabel.BackgroundTransparency = 1
speedLabel.TextColor3 = Color3.fromRGB(255,255,255)
speedLabel.Font = Enum.Font.Gotham
speedLabel.Text = "Speed: 16"

-- Slider
local slider = Instance.new("TextBox", frame)
slider.Size = UDim2.new(0.9,0,0,40)
slider.BackgroundColor3 = Color3.fromRGB(30,30,30)
slider.TextColor3 = Color3.fromRGB(255,255,255)
slider.PlaceholderText = "Enter Speed..."
slider.Text = ""

local sc = Instance.new("UICorner", slider)
sc.CornerRadius = UDim.new(0,10)

slider.FocusLost:Connect(function()
	local num = tonumber(slider.Text)
	if num then
		speedLabel.Text = "Speed: " .. num
		
		-- Hook into your own game
		local char = player.Character
		if char and char:FindFirstChild("Humanoid") then
			char.Humanoid.WalkSpeed = num
		end
	end
end)
